# =========================================================================
# Django Backend - Local Environment Configuration Template (.env.example)
# Rename this file to '.env' and fill in the actual values.
# =========================================================================

# -------------------------------------------------------------------------
# 1. Django Settings
# -------------------------------------------------------------------------
# Secret key for Django (generate a unique one for production)
SECRET_KEY=django-insecure-puv6kv)$735=-=71i*xk28t5ve726_=o(hgc#vxf-5@4jf_yo+

# Set to True for development, False for production
DEBUG=True

# Comma-separated list of allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1,www.jalgaon.com,api.jalgaon.com

# Comma-separated list of trusted origins for CSRF protection
CSRF_TRUSTED_ORIGINS=https://api.jalgaon.com,https://www.jalgaon.com,http://localhost:5173,http://127.0.0.1:5173

# Comma-separated list of origins allowed to make cross-site HTTP requests (CORS)
CORS_ALLOWED_ORIGINS=https://api.jalgaon.com,https://www.jalgaon.com,capacitor://localhost,http://localhost:5173,http://127.0.0.1:5173

# -------------------------------------------------------------------------
# 2. Database Configuration
# -------------------------------------------------------------------------
# Set to 'True' to run Django locally using SQLite (recommended for safe localhost development)
# If True, no Postgres server is required.
USE_SQLITE=True

# If USE_SQLITE=False, configure your PostgreSQL settings below:
# DB_ENGINE=django.db.backends.postgresql_psycopg2
# DB_NAME=jalgaon_database
# DB_USER=jalgaon-app
# DB_PASSWORD=your_production_or_local_postgres_password
# DB_HOST=127.0.0.1
# DB_PORT=5432

# -------------------------------------------------------------------------
# 3. Third-Party Integrations
# -------------------------------------------------------------------------
# Fast2SMS API Key for OTP authentication. 
# If left empty, Django will mock sending OTPs by printing them to the terminal.
FAST2SMS_API_KEY=
